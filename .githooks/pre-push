#!/usr/bin/env bash
# .githooks/pre-push
# Final safety net before pushing — scan all scenes in the branch.
#
# Installation: copied to .git/hooks/ by bin/install-hooks.sh (run by setup.sh)

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$PROJECT_ROOT/bin"

# Only run full scan if pushing to main/master
REMOTE="$1"
URL="$2"

# Quick scan: all scenes in the working tree
SCENES=$(find "$PROJECT_ROOT/scenes" -maxdepth 1 -mindepth 1 -type d 2>/dev/null || true)

if [[ -z "$SCENES" ]]; then
    exit 0
fi

FAIL=0
SKIP=0
for scene_dir in $SCENES; do
    # Skip directories without a renderable scene file (composite shots, etc.)
    if [[ ! -f "$scene_dir/scene.py" && ! -f "$scene_dir/scene.tsx" ]]; then
        SKIP=$((SKIP + 1))
        continue
    fi
    if ! bash "$SCRIPT_DIR/security-run.sh" "$scene_dir" >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        echo "  FAIL: $(basename "$scene_dir")"
    fi
done

if [[ "$FAIL" -gt 0 ]]; then
    echo ""
    echo "ERROR: Push rejected — $FAIL scene(s) failed security checks."
    echo "Run 'bin/security-run.sh <scene_dir>' for details."
    echo "Bypass with: git push --no-verify"
    exit 1
fi

exit 0
