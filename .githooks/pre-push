#!/usr/bin/env bash
# .githooks/pre-push
# Lightweight push gate: verifies scene files pass api-gate import checks.
#
# Installation: copied to .git/hooks/ by bin/install-hooks.sh (run by setup.sh)

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$PROJECT_ROOT/bin"

SCENES=$(find "$PROJECT_ROOT/scenes" -maxdepth 1 -mindepth 1 -type d 2>/dev/null || true)

if [[ -z "$SCENES" ]]; then
    exit 0
fi

FAIL=0
for scene_dir in $SCENES; do
    scene_file=""
    if [[ -f "$scene_dir/scene.py" ]]; then
        scene_file="$scene_dir/scene.py"
    elif [[ -f "$scene_dir/scene.tsx" ]]; then
        scene_file="$scene_dir/scene.tsx"
    else
        continue
    fi

    engine=$(python3 "$SCRIPT_DIR/project_engine.py" --scene-dir "$scene_dir" 2>/dev/null || echo "manimgl")
    sourcemap="$PROJECT_ROOT/engines/$engine/sourcemap.json"

    if [[ ! -f "$sourcemap" ]]; then
        continue
    fi

    if ! python3 "$SCRIPT_DIR/api-gate.py" "$scene_file" "$sourcemap" --engine "$engine" >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        echo "  FAIL: $(basename "$scene_dir") (api-gate)"
    fi
done

if [[ "$FAIL" -gt 0 ]]; then
    echo ""
    echo "ERROR: Push rejected — $FAIL scene(s) failed api-gate import checks."
    echo "Run 'python3 bin/api-gate.py <scene.py> engines/<engine>/sourcemap.json' for details."
    echo "Bypass with: git push --no-verify"
    exit 1
fi

exit 0
