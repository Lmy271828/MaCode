#!/usr/bin/env bash
# .githooks/pre-commit
# Intercept commits that modify protected primitives.
#
# Installation: copied to .git/hooks/ by bin/install-hooks.sh (run by setup.sh)

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# Protected file modifications
# Note: .githooks/ is NOT protected — hooks are versioned templates that
# must be updatable without --no-verify. The live copies in .git/hooks/
# are generated from templates and are not tracked.
PROTECTED_PATTERN='^(engines/|pipeline/|bin/|project\.yaml|requirements\.txt|package\.json)'

STAGED_PROTECTED=$(git diff --cached --name-only | grep -E "$PROTECTED_PATTERN" || true)

if [[ -n "$STAGED_PROTECTED" ]]; then
    echo ""
    echo "ERROR: Commit rejected — modifications to protected primitives detected:"
    echo "$STAGED_PROTECTED" | sed 's/^/  /'
    echo ""
    echo "If intentional, bypass with: git commit --no-verify"
    echo "Or move changes to a dedicated infrastructure PR."
    exit 1
fi

exit 0
