{
  "version": "1.2",
  "engine": "manimgl",
  "description": "Check registry for ManimGL engine scenes",
  "layers": {
    "layer1": {
      "description": "Static analysis — no rendering required",
      "checks": {
        "segment_consistency": {
          "name": "Segment Consistency",
          "description": "Validate manifest↔source segment alignment",
          "script": "bin/checks/segment_consistency.py",
          "engines": ["manim", "manimgl", "motion_canvas"],
          "enabled_by_default": true
        },
        "duration_consistency": {
          "name": "Duration Consistency",
          "description": "A1/A2 time checks: duration mismatch and animation overlap",
          "script": "bin/checks/duration_consistency.py",
          "engines": ["manim", "manimgl", "motion_canvas"],
          "enabled_by_default": true
        },
        "formula_density": {
          "name": "Formula Density",
          "description": "Check formula pixel density per segment",
          "script": "bin/checks/formula_density.py",
          "engines": ["manim", "manimgl", "motion_canvas"],
          "enabled_by_default": false
        },
        "shader_registry": {
          "name": "Shader Registry",
          "description": "Validate manifest shader declarations against assets/shaders/",
          "script": "bin/checks/shader_registry.py",
          "engines": ["manim", "manimgl", "motion_canvas"],
          "enabled_by_default": false
        }
      }
    },
    "layer2": {
      "description": "Runtime layout snapshot analysis",
      "checks": {
        "layout_overlap": {
          "name": "Layout Text Overlap",
          "description": "Runtime AABB text overlap detection via layout snapshots at keyframes",
          "script": "bin/checks/layout_overlap.py",
          "engines": ["manim", "manimgl", "motion_canvas"],
          "enabled_by_default": true
        }
      }
    },
    "layer3": {
      "description": "Full render / human review",
      "checks": {}
    }
  }
}
