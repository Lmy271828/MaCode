#!/usr/bin/env bash
set -euo pipefail

# bin/agent
# MaCode 项目配置检查与系统提示生成工具。
# 供人类用户或 Host Agent 调用，检查环境 readiness。
#
# 用法:
#   bin/agent --check         检查项目配置（引擎、安全门、api-gate、Git）
#   bin/agent --prompt        输出系统提示（供复制给其他 LLM）
#   bin/agent --help          显示帮助

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    cat <<'EOF'
Usage: agent [--check|--prompt|--help]

MaCode Agent — configuration check and prompt generator.

Options:
  --check    Check project configuration (engine, safety-gate, api-gate, Git)
  --prompt   Output system prompt (for copying to other LLMs)
  --help     Show this help

Examples:
  agent --check
  agent --prompt
EOF
    exit 0
fi

MODE="${1:-help}"

# ── 颜色 ────────────────────────────────────────────
BOLD='\033[1m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
CYAN='\033[36m'
RESET='\033[0m'

# ── 配置检查 ──────────────────────────────────────────
check_config() {
    local ok=true

    echo -e "${BOLD}MaCode Coding Agent — Configuration Check${RESET}"
    echo ""

    # 引擎
    ENGINE=$(grep -oP 'engine:\s*\K\S+' project.yaml 2>/dev/null || echo "manim")
    if [[ -f "engines/$ENGINE/SOURCEMAP.md" ]]; then
        echo -e "  ${GREEN}✓${RESET} Engine: $ENGINE (SOURCEMAP ready)"
    else
        echo -e "  ${YELLOW}~${RESET} Engine: $ENGINE (SOURCEMAP not found)"
    fi

    # 安全门
    if [[ -x "bin/safety-gate.sh" ]]; then
        echo -e "  ${GREEN}✓${RESET} safety-gate: active"
    else
        echo -e "  ${RED}✗${RESET} safety-gate: missing"
        ok=false
    fi

    # api-gate
    if [[ -x "bin/api-gate.py" ]] || [[ -f "bin/api-gate.py" ]]; then
        echo -e "  ${GREEN}✓${RESET} api-gate: active"
    else
        echo -e "  ${RED}✗${RESET} api-gate: missing"
        ok=false
    fi

    # Git
    if git rev-parse --git-dir >/dev/null 2>&1; then
        echo -e "  ${GREEN}✓${RESET} Git: available"
    else
        echo -e "  ${YELLOW}~${RESET} Git: not available (rollback disabled)"
    fi

    echo ""
    if $ok; then
        echo -e "${GREEN}All checks passed. Agent ready.${RESET}"
        return 0
    else
        echo -e "${RED}Fix issues above before starting agent.${RESET}"
        return 1
    fi
}

# ── 生成系统提示 ──────────────────────────────────────
generate_prompt() {
    ENGINE=$(grep -oP 'engine:\s*\K\S+' project.yaml 2>/dev/null || echo "manim")
    SOURCEMAP="engines/$ENGINE/SOURCEMAP.md"

    echo ""
    echo "================================================"
    echo "  MaCode Agent System Prompt"
    echo "================================================"
    echo ""

    # 核心指令
    cat << 'PROMPT'
你是一个 MaCode Harness 使用者 Agent，负责编写数学动画场景源码并通过 CLI 完成渲染、检查、修复的完整循环。

【环境】
- 工作目录是 MaCode 项目根目录
- 渲染引擎、管道脚本、SOURCEMAP 都已就绪
- 多 Agent 并发协调通过文件系统 claim 协议实现

【你的工作流】
1. 读取 project.yaml 了解项目配置与安全策略
2. 读取目标场景的 scenes/*/manifest.json 理解需求
3. 使用 macode inspect --grep <keyword> 查询引擎 API（勿 grep -r 整个源码树）
4. 编写场景源码到 scenes/<scene_name>/，创建 scene.py + manifest.json
5. 调用 macode check scenes/<scene_name>/ 运行静态检查
6. 读取 .agent/check_reports/*_static.json，修复 issue（fix_confidence >= 0.8 自动修复）
7. 调用 macode render scenes/<scene_name>/ 触发渲染（自动通过 api-gate + 缓存）
8. 若 api-gate 拦截，阅读违规列表，用 WHITELIST API 替代
9. 若渲染失败，tail .agent/log/ 查看日志和 SOURCEMAP 诊断
10. 调用 macode check scenes/<scene_name>/ --frames 运行帧检查
11. 修复 issue 后 git add scenes/<scene_name>/ && git commit
12. 后处理通过 pipeline/*.sh 完成（ffmpeg 拼接、音频、压缩）

【本机并行】
- PRD 不做 Multi-Agent：`render-scene.py` 无 scene claim，无 exit 4/5
- 多场并行优先 `render-all` / composite（`max_concurrent_scenes`）
- 可选 `curl localhost:<port>/api/state`（dashboard）观察进度
- 定期运行 `python3 bin/cleanup-stale.py` 修复 stalled state

【安全约束】
- 禁止导入 SOURCEMAP BLACKLIST 中的模块（manimlib、manim._config 等）
- 禁止使用 subprocess / os.system / socket / requests 等危险调用
- 禁止访问 .macode/ .claude/ .git/config
- 禁止 git push --force / git reset --hard
- 禁止修改 engines/、bin/、pipeline/ 下的文件
- 渲染超时 600 秒，帧数上限 10000

【SOURCEMAP 使用】
- macode inspect --grep <re>    搜索 WHITELIST API
- macode inspect --level P0     查看核心 API
- macode inspect --blacklist    查看禁止使用的模块

【关键脚本】
- macode render <dir>          渲染场景（含 api-gate + 缓存 + claim）
- macode check <dir>           静态检查（Layer 1）
- macode check <dir> --frames  帧检查（Layer 2）
- macode status                项目状态
- pipeline/preview.sh <mp4>    快速预览
- python3 bin/cleanup-stale.py 清理 dead-PID 和过期 claim
PROMPT

    echo ""

    # SOURCEMAP 上下文（P0/P1 API 速查）
    echo "────────────────────────────────────────────────"
    echo " 【引擎环境: $ENGINE】"
    echo "────────────────────────────────────────────────"
    echo ""
    if [[ -f "$SOURCEMAP" ]]; then
        echo "可用核心 API (P0/P1):"
        awk '/^## WHITELIST/{found=1; next} /^## /{if(found) exit} found && /^\|/ && !/ 标识 /' "$SOURCEMAP" | \
            while IFS='|' read -r _ id path purpose priority; do
                id=$(echo "$id" | xargs)
                priority=$(echo "$priority" | xargs)
                purpose=$(echo "$purpose" | xargs)
                if [[ "$priority" == "P0" || "$priority" == "P1" ]]; then
                    printf "  · %-30s [%s] %s\n" "$id" "$priority" "$purpose"
                fi
            done
        echo ""
        echo "禁止导入:"
        awk '/^## BLACKLIST/{found=1; next} /^## /{if(found) exit} found && /^\|/ && !/ 标识 /' "$SOURCEMAP" | \
            while IFS='|' read -r _ id path reason; do
                id=$(echo "$id" | xargs)
                reason=$(echo "$reason" | xargs)
                printf "  × %-30s %s\n" "$id" "$reason"
            done
    fi
    echo ""
    echo "================================================"

}

# ── 入口 ──────────────────────────────────────────────
case "$MODE" in
    --check)
        check_config
        ;;
    --prompt)
        generate_prompt
        ;;
    help|*)
        echo "MaCode Agent — 配置检查与提示生成工具"
        echo ""
        echo "用法:"
        echo "  bin/agent --check    检查项目配置"
        echo "  bin/agent --prompt   输出生成系统提示"
        echo ""
        echo "注意: MaCode 不再提供 agent-shell 入口。"
        echo "      Host Agent（Claude Code / Cursor 等）直接调用 CLI 工具即可。"
        echo "      人类用户如需交互式 shell，可运行: bash bin/human-tools/agent-shell"
        ;;
esac
