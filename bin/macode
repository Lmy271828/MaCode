#!/usr/bin/env bash
set -euo pipefail

# bin/macode
# MaCode 主入口 CLI。
#
# 用法:
#   macode render <scene_dir>     渲染单个场景
#   macode render-all              批量渲染所有场景
#   macode status                  显示项目状态
#   macode undo                    撤销最后一次 Agent 修改（git reset）
#   macode help                    显示帮助

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT"

# 读取 project.yaml（如果存在）
PROJECT_NAME="MaCode"
DEFAULT_ENGINE="manim"
if [[ -f "project.yaml" ]]; then
    if command -v yq >/dev/null 2>&1; then
        PROJECT_NAME=$(yq -r '.project.name // "MaCode"' project.yaml)
        DEFAULT_ENGINE=$(yq -r '.defaults.engine // "manim"' project.yaml)
    fi
fi

CMD="${1:-help}"

case "$CMD" in
    render)
        SCENE_DIR="${2:-}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode render <scene_dir> [--no-git]" >&2
            exit 1
        fi
        bash "$PROJECT_ROOT/pipeline/render.sh" "$SCENE_DIR"
        ;;

    render-all)
        bash "$PROJECT_ROOT/bin/render-all.sh"
        ;;

    status)
        echo "Project: $PROJECT_NAME"
        echo "Default engine: $DEFAULT_ENGINE"
        echo ""

        # 统计场景
        SCENE_COUNT=$(find scenes -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
        echo "Scenes: $SCENE_COUNT"
        if [[ "$SCENE_COUNT" -gt 0 ]]; then
            for scene_dir in $(find scenes -maxdepth 1 -mindepth 1 -type d | sort); do
                scene_name=$(basename "$scene_dir")
                manifest="$scene_dir/manifest.json"
                if [[ -f "$manifest" ]]; then
                    engine=$(grep -o '"engine"[[:space:]]*:[[:space:]]*"[^"]*"' "$manifest" 2>/dev/null | sed 's/.*"engine"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "?")
                    dirty=""
                    if git diff --quiet -- "$scene_dir" 2>/dev/null; then
                        :
                    else
                        dirty=" (dirty)"
                    fi
                    echo "  - $scene_name [$engine]$dirty"
                fi
            done
        fi
        echo ""

        # 上次渲染
        LAST_RENDER=$(find .agent/tmp -name "final.mp4" -type f 2>/dev/null | sort | tail -1)
        if [[ -n "$LAST_RENDER" ]]; then
            scene_name=$(basename "$(dirname "$LAST_RENDER")")
            duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$LAST_RENDER" 2>/dev/null || echo "?")
            echo "Last render: $scene_name — ${duration}s"
        else
            echo "Last render: none"
        fi

        echo ""
        # Git 状态
        if git rev-parse --git-dir >/dev/null 2>&1; then
            BRANCH=$(git branch --show-current 2>/dev/null || echo "?")
            COMMITS=$(git rev-list --count HEAD 2>/dev/null || echo "0")
            echo "Git branch: $BRANCH ($COMMITS commits)"
            if ! git diff --quiet 2>/dev/null; then
                echo "Uncommitted changes: yes"
            fi
        fi
        ;;

    undo)
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "Error: not a git repository" >&2
            exit 1
        fi

        # 查找最近的 agent 分支合并
        LAST_AGENT=$(git log --oneline --grep="agent:" -1 2>/dev/null | awk '{print $1}')
        if [[ -z "$LAST_AGENT" ]]; then
            echo "No Agent commits found to undo." >&2
            exit 1
        fi

        echo "Undoing last Agent change: $(git log --oneline -1 "$LAST_AGENT")"
        git revert --no-commit "$LAST_AGENT"
        git reset HEAD
        echo "Changes from $LAST_AGENT have been reverted (uncommitted)."
        echo "Review with 'git diff' and commit when ready."
        ;;

    inspect)
        # 查询 SOURCEMAP（统一通过 JSON 消费）
        # 用法: macode inspect [engine] [--grep <re>] [--level P0|P1|P2] [--blacklist]
        GREP=""
        LEVEL=""
        BLACKLIST_ONLY=false
        FORMAT="text"
        ENGINE="$DEFAULT_ENGINE"

        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --grep)   GREP="$2"; shift 2 ;;
                --level)  LEVEL="$2"; shift 2 ;;
                --blacklist) BLACKLIST_ONLY=true; shift ;;
                --format) FORMAT="$2"; shift 2 ;;
                -*)       shift ;;  # 跳过未知 flag
                *)        ENGINE="$1"; shift ;;  # 第一个非 flag 参数 = 引擎名
            esac
        done

        SOURCEMAP="engines/${ENGINE}/SOURCEMAP.md"
        if [[ ! -f "$SOURCEMAP" ]]; then
            echo "Error: SOURCEMAP.md not found for engine '$ENGINE'" >&2
            echo "Run: macode sourcemap init $ENGINE" >&2
            exit 1
        fi

        # 确保 JSON 机器接口存在且新鲜
        if ! python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$ENGINE" >/dev/null 2>&1; then
            echo "[macode] Syncing SOURCEMAP to JSON..." >&2
            if ! python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" "$ENGINE" >/dev/null 2>&1; then
                echo "Error: Failed to sync SOURCEMAP for '$ENGINE'" >&2
                exit 1
            fi
        fi

        # 构建 sourcemap-read 参数
        READ_ARGS=()
        [[ -n "$GREP" ]] && READ_ARGS+=("--grep" "$GREP")
        [[ -n "$LEVEL" ]] && READ_ARGS+=("--level" "$LEVEL")
        [[ "$FORMAT" == "json" ]] && READ_ARGS+=("--format" "json")

        if $BLACKLIST_ONLY; then
            echo "=== BLACKLIST ($ENGINE) ==="
            bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" blacklist "${READ_ARGS[@]}"
        else
            echo "=== WHITELIST ($ENGINE) ==="
            bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" whitelist "${READ_ARGS[@]}"

            # Show redirects when grep keywords match common pitfalls
            if [[ -n "$GREP" ]]; then
                GREP_LOWER="${GREP,,}"
                if [[ "$GREP_LOWER" =~ fade|filtergraph|cases|matrix|shader|regex|ffmpeg|amix|gl_position|align ]]; then
                    echo ""
                    echo "--- REDIRECT: You may be writing raw syntax ---"
                    bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" redirect --grep "$GREP" 2>/dev/null || true
                fi
            fi
        fi
        ;;

    engine)
        # 显示所有引擎的状态（版本、兼容声明、SOURCEMAP 新鲜度）
        echo "=== Engine Status ==="
        echo ""
        for engine_dir in "$PROJECT_ROOT"/engines/*/; do
            engine_name=$(basename "$engine_dir")
            conf="$engine_dir/engine.conf"
            sourcemap="$engine_dir/SOURCEMAP.md"
            if [[ ! -f "$conf" ]]; then
                continue
            fi

            echo "--- $engine_name ---"

            # 实际安装版本
            version_cmd=$(grep "^version_cmd:" "$conf" | sed 's/^version_cmd:[[:space:]]*//;s/^"//;s/"$//' | head -1)
            # 解码 engine.conf 中转义的双引号（\" → "）
            version_cmd="${version_cmd//\\\"/\"}"
            if [[ -n "$version_cmd" ]]; then
                installed=$(eval "$version_cmd" 2>/dev/null || echo "unknown")
                echo "  Installed: v$installed"
            fi

            # SOURCEMAP 声明版本
            if [[ -f "$sourcemap" ]]; then
                map_ver=$(grep "引擎版本" "$sourcemap" 2>/dev/null | head -1 | sed 's/.*引擎版本:[[:space:]]*//' | xargs)
                adapter_ver=$(grep "适配层版本" "$sourcemap" 2>/dev/null | head -1 | sed 's/.*适配层版本:[[:space:]]*//' | xargs)
                echo "  Sourcemap: v$map_ver | Adapter: $adapter_ver"
            fi

            # 兼容声明（预留接口）
            compat=$(grep -A1 "engine_semver:" "$conf" 2>/dev/null | tail -1 | sed 's/^[[:space:]]*- //;s/^[[:space:]]*//' | xargs)
            if [[ -n "$compat" ]]; then
                echo "  Compatibility: $compat"
            fi

            # SOURCEMAP JSON 新鲜度
            if [[ -f ".agent/context/${engine_name}_sourcemap.json" ]]; then
                if python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$engine_name" >/dev/null 2>&1; then
                    echo "  JSON sync: ✓ fresh"
                else
                    echo "  JSON sync: ✗ stale (run: macode sourcemap validate $engine_name)"
                fi
            else
                echo "  JSON sync: ✗ missing (run: sourcemap-sync.py $engine_name)"
            fi
            echo ""
        done
        ;;

    migrate)
        SCENE_DIR="${2:-}"
        TARGET_ENGINE="${3:-manim}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode migrate <scene_dir> [target_engine=manim]" >&2
            exit 1
        fi
        echo "[migrate] TODO: migrate $SCENE_DIR to $TARGET_ENGINE"
        echo "  This will:"
        echo "    1. Read manifest.json"
        echo "    2. Convert scene.py imports from source engine to target engine"
        echo "    3. Update manifest.json engine field"
        echo "  For now, please do this manually."
        ;;

    sourcemap)
        SUB="${2:-help}"
        ENGINE="${3:-$DEFAULT_ENGINE}"
        case "$SUB" in
            init)
                echo "Run: engines/$ENGINE/scripts/inspect.sh  to explore the engine"
                echo "Then: engines/$ENGINE/scripts/validate_sourcemap.sh  to verify paths"
                echo "SOURCEMAP location: engines/$ENGINE/SOURCEMAP.md"
                ;;
            validate)
                # 先 lint，再验证路径
                echo "[macode] Linting SOURCEMAP..."
                if ! python3 "$PROJECT_ROOT/bin/sourcemap-lint.py" "$PROJECT_ROOT/engines/$ENGINE/SOURCEMAP.md"; then
                    exit 1
                fi
                echo "[macode] Validating paths..."
                bash "$PROJECT_ROOT/engines/$ENGINE/scripts/validate_sourcemap.sh"
                ;;
            help|*)
                echo "Usage: macode sourcemap <init|validate> [engine]"
                echo "  init       Show instructions for creating SOURCEMAP"
                echo "  validate   Run validate_sourcemap.sh for the engine"
                ;;
        esac
        ;;

    help|*)
        echo "MaCode — Math Animation Harness"
        echo ""
        echo "Usage: macode <command> [args]"
        echo ""
        echo "Commands:"
        echo "  render <scene_dir>     Render a single scene"
        echo "  render-all             Render all scenes"
        echo "  status                 Show project status"
        echo "  undo                   Revert last Agent change"
        echo "  engine                 Show engine status & compatibility"
        echo "  inspect [--grep <re>]  Query SOURCEMAP WHITELIST"
        echo "    --blacklist           Show BLACKLIST instead"
        echo "    --level P0|P1|P2     Filter by priority"
        echo "  sourcemap <init|validate> [engine]"
        echo "                         Manage SOURCEMAP.md"
        echo "  migrate <scene_dir> [target_engine]"
        echo "                         Migrate scene to another engine"
        echo "  help                   Show this help"
        ;;
esac
