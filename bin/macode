#!/usr/bin/env bash
set -euo pipefail

# bin/macode
# MaCode 主入口 CLI。
#
# 用法:
#   macode render <scene_dir>     渲染单个场景
#   macode render-all              批量渲染所有场景
#   macode status                  显示项目状态
#   macode undo                    撤销最后一次 Agent 修改（git reset）
#   macode help                    显示帮助

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT"

# 读取 project.yaml：唯一真源；缺失或缺字段时 fail-loud 退出
# （PRD §8.1 已选型；不再在多处硬编码 fallback 字面量）
PROJECT_NAME="MaCode"
DEFAULT_ENGINE=""
if [[ ! -f "project.yaml" ]]; then
    echo "Error: project.yaml missing at $PROJECT_ROOT/project.yaml" >&2
    echo "  See docs/PRD-draft.md §8.1 — project.yaml is the canonical config source." >&2
    exit 2
fi
if command -v yq >/dev/null 2>&1; then
    PROJECT_NAME=$(yq -r '.project.name // "MaCode"' project.yaml)
    DEFAULT_ENGINE=$(yq -r '.defaults.engine // ""' project.yaml)
else
    # Prefer venv python only if it can actually import yaml
    _PY="python3"
    if [[ -x "$PROJECT_ROOT/.venv/bin/python" ]] && "$PROJECT_ROOT/.venv/bin/python" -c 'import yaml' >/dev/null 2>&1; then
        _PY="$PROJECT_ROOT/.venv/bin/python"
    fi
    PROJECT_NAME=$(
        "$_PY" -c 'import yaml, pathlib; d=yaml.safe_load(pathlib.Path("project.yaml").read_text()) or {}; p=d.get("project"); p=p if isinstance(p, dict) else {}; print(p.get("name") or "MaCode")'
    )
    DEFAULT_ENGINE=$(
        "$_PY" -c 'import yaml, pathlib; d=yaml.safe_load(pathlib.Path("project.yaml").read_text()) or {}; g=d.get("defaults"); g=g if isinstance(g, dict) else {}; print(g.get("engine") or "")'
    )
fi
if [[ -z "$DEFAULT_ENGINE" ]]; then
    echo "Error: project.yaml missing 'defaults.engine'" >&2
    echo "  Set 'defaults.engine: <name>' to one of: $(ls -d engines/*/ 2>/dev/null | xargs -n1 basename | tr '\n' ' ')" >&2
    exit 2
fi

CMD="${1:-help}"

case "$CMD" in
    render)
        SCENE_DIR="${2:-}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode render <scene_dir> [--no-git]" >&2
            exit 1
        fi

        shift 2
        bash "$PROJECT_ROOT/pipeline/render.sh" "$SCENE_DIR" "$@"
        ;;

    dev)
        SCENE_DIR="${2:-}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode dev <scene_dir> [--segment <seg_id>] [--snapshot [time]] [--watch] [--port <n>]" >&2
            exit 1
        fi
        shift 2
        bash "$PROJECT_ROOT/bin/macode-dev.sh" "$SCENE_DIR" "$@"
        ;;

    check)
        SCENE_DIR="${2:-}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode check <scene_dir> [--static|--frames]" >&2
            exit 1
        fi
        shift 2
        CHECK_TYPE="${1:-all}"
        SCENE_NAME=$(basename "$SCENE_DIR")
        mkdir -p "$PROJECT_ROOT/.agent/check_reports"
        case "$CHECK_TYPE" in
            --static)
                python3 "$PROJECT_ROOT/bin/check-static.py" "$SCENE_DIR" --output "$PROJECT_ROOT/.agent/check_reports/${SCENE_NAME}_static.json"
                ;;
            --frames)
                python3 "$PROJECT_ROOT/bin/check-frames.py" "$SCENE_DIR" --output "$PROJECT_ROOT/.agent/check_reports/${SCENE_NAME}_frames.json"
                ;;
            all|""|-*)
                echo "=== Static check ==="
                python3 "$PROJECT_ROOT/bin/check-static.py" "$SCENE_DIR" --output "$PROJECT_ROOT/.agent/check_reports/${SCENE_NAME}_static.json"
                echo ""
                echo "=== Frame check ==="
                python3 "$PROJECT_ROOT/bin/check-frames.py" "$SCENE_DIR" --output "$PROJECT_ROOT/.agent/check_reports/${SCENE_NAME}_frames.json"
                ;;
        esac
        ;;

    composite-unified)
        SUB="${2:-}"
        if [[ -z "$SUB" ]]; then
            echo "Usage: macode composite <info|render|init|add-segment> [args]" >&2
            exit 1
        fi
        case "$SUB" in
            info)
                SCENE_DIR="${3:-}"
                if [[ -z "$SCENE_DIR" ]]; then
                    echo "Usage: macode composite info <scene_dir>" >&2
                    exit 1
                fi
                if [[ ! -f "$SCENE_DIR/manifest.json" ]]; then
                    echo "Error: manifest.json not found in $SCENE_DIR" >&2
                    exit 1
                fi
                python3 - "$SCENE_DIR" <<'PY'
import json, os, sys
scene_dir = sys.argv[1]
with open(os.path.join(scene_dir, 'manifest.json')) as f:
    manifest = json.load(f)
print(f"Scene: {os.path.basename(os.path.normpath(scene_dir))}")
print(f"Type: {manifest.get('type', 'scene')}")
print("")
print("Segments:")
total = 0.0
for seg in manifest.get('segments', []):
    seg_path = seg.get('scene_dir') or seg.get('shot') or 'N/A'
    trans = seg.get('transition')
    trans_str = f" [transition: {trans['type']} {trans['duration']}s]" if trans else ""
    print(f"  - {seg['id']}: {seg_path}{trans_str}")
    dmanifest = os.path.join(scene_dir, seg_path, 'manifest.json')
    if os.path.isfile(dmanifest):
        with open(dmanifest) as f:
            data = json.load(f)
        dur = float(data.get('duration', 0))
        print(f"    duration: {dur}s")
        total += dur
print("")
print(f"Total (raw): {total:.2f}s")
PY
                ;;
            render)
                SCENE_DIR="${3:-}"
                if [[ -z "$SCENE_DIR" ]]; then
                    echo "Usage: macode composite render <scene_dir>" >&2
                    exit 1
                fi
                shift 3
                bash "$PROJECT_ROOT/pipeline/render.sh" "$SCENE_DIR" "$@"
                ;;
            init)
                shift 2
                python3 "$PROJECT_ROOT/bin/composite-init.py" init "$@"
                ;;
            add-segment)
                shift 2
                python3 "$PROJECT_ROOT/bin/composite-init.py" add-segment "$@"
                ;;
            *)
                echo "Unknown composite subcommand: $SUB" >&2
                echo "Usage: macode composite <info|render|init|add-segment> [args]" >&2
                exit 1
                ;;
        esac
        ;;

    report)
        SCENE_DIR="${2:-}"
        if [[ -z "$SCENE_DIR" ]]; then
            echo "Usage: macode report <scene_dir> [--open]" >&2
            exit 1
        fi
        shift 2
        python3 "$PROJECT_ROOT/bin/report-generator.py" "$SCENE_DIR"
        REPORT_FILE="$PROJECT_ROOT/.agent/reports/$(basename "$SCENE_DIR")/index.html"
        if [[ "${1:-}" == "--open" && -f "$REPORT_FILE" ]]; then
            echo "Opening $REPORT_FILE ..."
            xdg-open "$REPORT_FILE" 2>/dev/null || open "$REPORT_FILE" 2>/dev/null || echo "Report: $REPORT_FILE"
        else
            echo "Report: $REPORT_FILE"
        fi
        ;;

    timeline)
        python3 "$PROJECT_ROOT/bin/timeline-generator.py"
        REPORT_FILE="$PROJECT_ROOT/.agent/reports/timeline.html"
        if [[ "${2:-}" == "--open" && -f "$REPORT_FILE" ]]; then
            echo "Opening $REPORT_FILE ..."
            xdg-open "$REPORT_FILE" 2>/dev/null || open "$REPORT_FILE" 2>/dev/null || echo "Timeline: $REPORT_FILE"
        else
            echo "Timeline: $REPORT_FILE"
        fi
        ;;

    render-all)
        bash "$PROJECT_ROOT/bin/render-all.sh"
        ;;

    status)
        echo "Project: $PROJECT_NAME"
        echo "Default engine: $DEFAULT_ENGINE"
        echo ""

        # 统计场景
        SCENE_COUNT=$(find scenes -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l)
        echo "Scenes: $SCENE_COUNT"
        if [[ "$SCENE_COUNT" -gt 0 ]]; then
            for scene_dir in $(find scenes -maxdepth 1 -mindepth 1 -type d | sort); do
                scene_name=$(basename "$scene_dir")
                manifest="$scene_dir/manifest.json"
                if [[ -f "$manifest" ]]; then
                    engine=$(grep -o '"engine"[[:space:]]*:[[:space:]]*"[^"]*"' "$manifest" 2>/dev/null | sed 's/.*"engine"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || echo "?")
                    dirty=""
                    if git diff --quiet -- "$scene_dir" 2>/dev/null; then
                        :
                    else
                        dirty=" (dirty)"
                    fi
                    echo "  - $scene_name [$engine]$dirty"
                fi
            done
        fi
        echo ""

        # SOURCEMAP 健康状态
        echo "SOURCEMAP health:"
        if [[ -f "$PROJECT_ROOT/bin/sourcemap-version-check.py" ]]; then
            python3 "$PROJECT_ROOT/bin/sourcemap-version-check.py" --all 2>&1 | sed 's/^/  /'
        else
            echo "  ~ sourcemap-version-check.py not found"
        fi
        echo ""

        # 上次渲染
        LAST_RENDER=$(find .agent/tmp -name "final.mp4" -type f 2>/dev/null | sort | tail -1)
        if [[ -n "$LAST_RENDER" ]]; then
            scene_name=$(basename "$(dirname "$LAST_RENDER")")
            duration=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$LAST_RENDER" 2>/dev/null || echo "?")
            echo "Last render: $scene_name — ${duration}s"
        else
            echo "Last render: none"
        fi

        echo ""
        # Git 状态
        if git rev-parse --git-dir >/dev/null 2>&1; then
            BRANCH=$(git branch --show-current 2>/dev/null || echo "?")
            COMMITS=$(git rev-list --count HEAD 2>/dev/null || echo "0")
            echo "Git branch: $BRANCH ($COMMITS commits)"
            if ! git diff --quiet 2>/dev/null; then
                echo "Uncommitted changes: yes"
            fi
        fi
        ;;

    undo)
        if ! git rev-parse --git-dir >/dev/null 2>&1; then
            echo "Error: not a git repository" >&2
            exit 1
        fi

        # 查找最近的 agent 分支合并
        LAST_AGENT=$(git log --oneline --grep="agent:" -1 2>/dev/null | awk '{print $1}')
        if [[ -z "$LAST_AGENT" ]]; then
            echo "No Agent commits found to undo." >&2
            exit 1
        fi

        echo "Undoing last Agent change: $(git log --oneline -1 "$LAST_AGENT")"
        git revert --no-commit "$LAST_AGENT"
        git reset HEAD
        echo "Changes from $LAST_AGENT have been reverted (uncommitted)."
        echo "Review with 'git diff' and commit when ready."
        ;;

    inspect)
        # 查询 SOURCEMAP（统一通过 JSON 消费）
        # 用法: macode inspect [engine] [--grep <re>] [--level P0|P1|P2] [--blacklist]
        GREP=""
        LEVEL=""
        BLACKLIST_ONLY=false
        FORMAT="text"
        ENGINE="$DEFAULT_ENGINE"

        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --grep)   GREP="$2"; shift 2 ;;
                --level)  LEVEL="$2"; shift 2 ;;
                --blacklist) BLACKLIST_ONLY=true; shift ;;
                --format) FORMAT="$2"; shift 2 ;;
                -*)       shift ;;  # 跳过未知 flag
                *)        ENGINE="$1"; shift ;;  # 第一个非 flag 参数 = 引擎名
            esac
        done

        SOURCEMAP="engines/${ENGINE}/SOURCEMAP.md"
        if [[ ! -f "$SOURCEMAP" ]]; then
            echo "Error: SOURCEMAP.md not found for engine '$ENGINE'" >&2
            echo "Run: macode sourcemap init $ENGINE" >&2
            exit 1
        fi

        # 确保 JSON 机器接口存在且新鲜
        if ! python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$ENGINE" >/dev/null 2>&1; then
            echo "[macode] Syncing SOURCEMAP to JSON..." >&2
            if ! python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" "$ENGINE" >/dev/null 2>&1; then
                echo "Error: Failed to sync SOURCEMAP for '$ENGINE'" >&2
                exit 1
            fi
        fi

        # 构建 sourcemap-read 参数
        READ_ARGS=()
        [[ -n "$GREP" ]] && READ_ARGS+=("--grep" "$GREP")
        [[ -n "$LEVEL" ]] && READ_ARGS+=("--level" "$LEVEL")
        [[ "$FORMAT" == "json" ]] && READ_ARGS+=("--format" "json")

        if $BLACKLIST_ONLY; then
            echo "=== BLACKLIST ($ENGINE) ==="
            bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" blacklist "${READ_ARGS[@]}"
        else
            echo "=== WHITELIST ($ENGINE) ==="
            bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" whitelist "${READ_ARGS[@]}"

            # Show redirects when grep keywords match common pitfalls
            if [[ -n "$GREP" ]]; then
                GREP_LOWER="${GREP,,}"
                if [[ "$GREP_LOWER" =~ fade|filtergraph|cases|matrix|shader|regex|ffmpeg|amix|gl_position|align ]]; then
                    echo ""
                    echo "--- REDIRECT: You may be writing raw syntax ---"
                    bash "$PROJECT_ROOT/bin/sourcemap-read" "$ENGINE" redirect --grep "$GREP" 2>/dev/null || true
                fi
            fi
        fi
        ;;

    engine)
        # 显示所有引擎的状态（版本、兼容声明、SOURCEMAP 新鲜度）
        echo "=== Engine Status ==="
        echo ""
        for engine_dir in "$PROJECT_ROOT"/engines/*/; do
            engine_name=$(basename "$engine_dir")
            conf="$engine_dir/engine.conf"
            sourcemap="$engine_dir/SOURCEMAP.md"
            if [[ ! -f "$conf" ]]; then
                continue
            fi

            echo "--- $engine_name ---"

            # 实际安装版本
            version_cmd=$(grep "^version_cmd:" "$conf" | sed 's/^version_cmd:[[:space:]]*//;s/^"//;s/"$//' | head -1)
            # 解码 engine.conf 中转义的双引号（\" → "）
            version_cmd="${version_cmd//\\\"/\"}"
            if [[ -n "$version_cmd" ]]; then
                installed=$(eval "$version_cmd" 2>/dev/null || echo "unknown")
                echo "  Installed: v$installed"
            fi

            # SOURCEMAP 声明版本
            if [[ -f "$sourcemap" ]]; then
                map_ver=$(grep "引擎版本" "$sourcemap" 2>/dev/null | head -1 | sed 's/.*引擎版本:[[:space:]]*//' | xargs)
                adapter_ver=$(grep "适配层版本" "$sourcemap" 2>/dev/null | head -1 | sed 's/.*适配层版本:[[:space:]]*//' | xargs)
                echo "  Sourcemap: v$map_ver | Adapter: $adapter_ver"
            fi

            # 兼容声明（预留接口）
            compat=$(grep -A1 "engine_semver:" "$conf" 2>/dev/null | tail -1 | sed 's/^[[:space:]]*- //;s/^[[:space:]]*//' | xargs)
            if [[ -n "$compat" ]]; then
                echo "  Compatibility: $compat"
            fi

            # SOURCEMAP JSON 新鲜度
            if [[ -f ".agent/context/${engine_name}_sourcemap.json" ]]; then
                if python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$engine_name" >/dev/null 2>&1; then
                    echo "  JSON sync: ✓ fresh"
                else
                    echo "  JSON sync: ✗ stale (run: macode sourcemap validate $engine_name)"
                fi
            else
                echo "  JSON sync: ✗ missing (run: sourcemap-sync.py $engine_name)"
            fi
            echo ""
        done
        ;;

    sourcemap)
        SUB="${2:-help}"
        case "$SUB" in
            generate-md|--sync)
                if [[ "${3:-}" == "--all" ]]; then
                    python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --all
                elif [[ -n "${3:-}" ]]; then
                    python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" "$3"
                else
                    python3 "$PROJECT_ROOT/bin/sourcemap-sync.py"
                fi
                ;;
            scan-api)
                python3 "$PROJECT_ROOT/bin/sourcemap-scan-api.py" "${@:3}"
                ;;
            version-check)
                python3 "$PROJECT_ROOT/bin/sourcemap-version-check.py" "${@:3}"
                ;;
            init)
                ENGINE="${3:-$DEFAULT_ENGINE}"
                echo "Canonical blacklist/whitelist live in engines/$ENGINE/sourcemap.json"
                echo "Run: engines/$ENGINE/scripts/inspect.sh  to explore the engine"
                echo "Then: engines/$ENGINE/scripts/validate_sourcemap.sh  after macode sourcemap validate $ENGINE"
                echo "SOURCEMAP.md is a generated human view (macode sourcemap generate-md $ENGINE)."
                ;;
            validate)
                ENGINE="${3:-$DEFAULT_ENGINE}"
                if [[ "$ENGINE" == "--all" ]]; then
                    for engine_dir in "$PROJECT_ROOT"/engines/*/; do
                        en=$(basename "$engine_dir")
                        [[ -f "$engine_dir/sourcemap.json" ]] || continue
                        echo "[macode] sourcemap-sync --check $en"
                        python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$en" || exit 1
                        echo "[macode] validate_sourcemap.sh $en"
                        bash "$PROJECT_ROOT/engines/$en/scripts/validate_sourcemap.sh" || exit 1
                    done
                else
                    echo "[macode] sourcemap-sync --check $ENGINE"
                    python3 "$PROJECT_ROOT/bin/sourcemap-sync.py" --check "$ENGINE" || exit 1
                    echo "[macode] validate_sourcemap.sh $ENGINE"
                    bash "$PROJECT_ROOT/engines/$ENGINE/scripts/validate_sourcemap.sh"
                fi
                ;;
            help|*)
                echo "Usage: macode sourcemap <SUBCOMMAND> [args]"
                echo "  generate-md [engine|--all]   Regenerate SOURCEMAP.md + .agent/context from sourcemap.json (default: project default engine)"
                echo "  validate [engine|--all]      sourcemap-sync --check + validate_sourcemap.sh"
                echo "  scan-api [engine ...]        Forward to sourcemap-scan-api.py"
                echo "  version-check [args ...]     Forward to sourcemap-version-check.py"
                echo "  init [engine]                Show where to edit canonical sourcemap"
                ;;
        esac
        ;;

    shader)
        SUB="${2:-help}"
        case "$SUB" in
            list)
                REGISTRY="$PROJECT_ROOT/assets/shaders/_registry.json"
                if [[ -f "$REGISTRY" ]]; then
                    echo "Available shader assets (Layer 2):"
                    python3 -c "
import json, sys
with open('$REGISTRY') as f:
    reg = json.load(f)
for s in reg.get('assets', []):
    cat = s.get('category', 'unknown')
    typ = s.get('type', 'unknown')
    print(f\"  {s['id']:<30} [{cat}/{typ}]  {s.get('description', '')}\")
"
                else
                    echo "No shader registry found. Expected: $REGISTRY" >&2
                    exit 1
                fi
                ;;
            render)
                SHADER_DIR="${3:-}"
                if [[ -z "$SHADER_DIR" ]]; then
                    echo "Usage: macode shader render <shader_dir> [--fps <n>] [--duration <sec>] [--resolution <WxH>]" >&2
                    exit 1
                fi
                shift 3
                python3 "$PROJECT_ROOT/bin/shader-render.py" "$SHADER_DIR" "$@"
                ;;
            extract)
                SHADER_NAME="${3:-}"
                OUTPUT_DIR="${4:-}"
                if [[ -z "$SHADER_NAME" || -z "$OUTPUT_DIR" ]]; then
                    echo "Usage: macode shader extract <builtin_name> <output_dir>" >&2
                    echo "  Example: macode shader extract quadratic_bezier/fill assets/shaders/extracted/qb_fill/" >&2
                    exit 1
                fi
                PYTHONPATH="$PROJECT_ROOT/engines/manimgl/src:$PYTHONPATH" \
                    python3 -c "
from utils.shader_extractor import extract_builtin_shader, save_shader_asset
import sys
try:
    data = extract_builtin_shader('$SHADER_NAME')
    save_shader_asset(data, '$OUTPUT_DIR')
    print(f'Extracted {data[\"name\"]} → $OUTPUT_DIR')
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
"
                ;;
            help|*)
                echo "Usage: macode shader <list|render|extract> [args]"
                echo "  list                          List available shader assets"
                echo "  render <shader_dir> [opts]    Compile Layer 2 asset to Layer 1 PNG frames"
                echo "    --fps <n>                   Override fps"
                echo "    --duration <sec>            Override duration"
                echo "    --resolution <WxH>          Override resolution"
                echo "  extract <name> <out_dir>      Extract built-in manimlib shader"
                ;;
        esac
        ;;

    mc)
        SUB="${2:-help}"
        case "$SUB" in
            serve)
                SCENE_DIR="${3:-}"
                if [[ -z "$SCENE_DIR" ]]; then
                    echo "Usage: macode mc serve <scene_dir> [port]" >&2
                    exit 1
                fi
                shift 3
                node "$PROJECT_ROOT/engines/motion_canvas/scripts/render.mjs" --serve-only "$SCENE_DIR" "$@"
                ;;
            stop)
                SCENE_DIR="${3:-}"
                if [[ -z "$SCENE_DIR" ]]; then
                    echo "Usage: macode mc stop <scene_dir>" >&2
                    exit 1
                fi
                node "$PROJECT_ROOT/engines/motion_canvas/scripts/render.mjs" --stop "$SCENE_DIR"
                ;;
            help|*)
                echo "Usage: macode mc <serve|stop> [args]"
                echo "  serve <scene_dir> [port]    Start Motion Canvas dev server"
                echo "  stop <scene_dir>            Stop Motion Canvas dev server"
                ;;
        esac
        ;;

    cleanup)
        shift 1
        python3 "$PROJECT_ROOT/bin/cleanup-stale.py" "$@"
        ;;

    dry-run)
        SCENE_FILE="${2:-}"
        if [[ -z "$SCENE_FILE" ]]; then
            echo "Usage: macode dry-run <scene_file> [engine]" >&2
            exit 1
        fi
        shift 2
        python3 "$PROJECT_ROOT/bin/dry-run.py" "$SCENE_FILE" "$@"
        ;;

    test)
        shift 1
        # Default: run all tests
        RUN_UNIT=0
        RUN_INTEGRATION=0
        RUN_SMOKE=0
        RUN_LINT=0
        PASS_THROUGH_ARGS=()

        while [[ $# -gt 0 ]]; do
            case "$1" in
                --unit)
                    RUN_UNIT=1
                    shift
                    ;;
                --integration)
                    RUN_INTEGRATION=1
                    shift
                    ;;
                --smoke)
                    RUN_SMOKE=1
                    shift
                    ;;
                --lint)
                    RUN_LINT=1
                    shift
                    ;;
                --all)
                    RUN_UNIT=1
                    RUN_INTEGRATION=1
                    RUN_SMOKE=1
                    RUN_LINT=1
                    shift
                    ;;
                --verbose|-k|--fail-fast)
                    PASS_THROUGH_ARGS+=("$1")
                    shift
                    ;;
                *)
                    # Backward compatibility: positional suite name
                    if [[ "$1" == "unit" ]]; then
                        RUN_UNIT=1
                    elif [[ "$1" == "integration" ]]; then
                        RUN_INTEGRATION=1
                    elif [[ "$1" == "smoke" ]]; then
                        RUN_SMOKE=1
                    elif [[ "$1" == "all" ]]; then
                        RUN_UNIT=1
                        RUN_INTEGRATION=1
                        RUN_SMOKE=1
                    else
                        PASS_THROUGH_ARGS+=("$1")
                    fi
                    shift
                    ;;
            esac
        done

        # If no specific suite selected, run all tests (but not lint)
        if [[ "$RUN_UNIT" -eq 0 && "$RUN_INTEGRATION" -eq 0 && "$RUN_SMOKE" -eq 0 && "$RUN_LINT" -eq 0 ]]; then
            RUN_UNIT=1
            RUN_INTEGRATION=1
            RUN_SMOKE=1
        fi

        FAILED=0

        if [[ "$RUN_LINT" -eq 1 ]]; then
            echo "[macode test] Running lint..."
            if command -v ruff >/dev/null 2>&1; then
                ruff check "$PROJECT_ROOT/bin" "$PROJECT_ROOT/pipeline" "$PROJECT_ROOT/engines" "$PROJECT_ROOT/tests" || FAILED=1
            else
                echo "[macode test] ruff not installed, skipping lint" >&2
            fi
        fi

        if [[ "$RUN_UNIT" -eq 1 ]]; then
            echo "[macode test] Running unit tests..."
            pytest "$PROJECT_ROOT/tests/unit/" -v "${PASS_THROUGH_ARGS[@]}" || FAILED=1
        fi

        if [[ "$RUN_INTEGRATION" -eq 1 ]]; then
            echo "[macode test] Running integration tests..."
            bash "$PROJECT_ROOT/tests/integration/runner.sh" "${PASS_THROUGH_ARGS[@]}" || FAILED=1
        fi

        if [[ "$RUN_SMOKE" -eq 1 ]]; then
            echo "[macode test] Running smoke tests..."
            bash "$PROJECT_ROOT/tests/smoke/runner.sh" "${PASS_THROUGH_ARGS[@]}" || FAILED=1
        fi

        exit "$FAILED"
        ;;

    help|--help|-h|*)
        cat <<'EOF'
MaCode — Math Animation Harness

Usage: macode <command> [args]

Commands:
  render <scene_dir>              Render a single scene
  render-all                      Render all scenes
  composite <info|render|init|add-segment> [args]
                                  Composite-unified scene operations
  dev <scene_dir>                 Interactive dev mode (watch + preview)
    --segment <seg_id>            Seek to specific segment (manimgl only)
    --snapshot [time]             Capture a single preview frame (Motion Canvas)
    --watch                       Watch file changes and auto-snapshot
    --port <n>                    Vite dev server port (default: 4567)
  check <scene_dir>               Run static + frame checks
    --static                      Run only static check
    --frames                      Run only frame check
  report <scene_dir>              Generate HTML report for scene
    --open                        Open report in browser
  timeline                        Generate project timeline (all scenes)
    --open                        Open timeline in browser
  shader <list|render|extract>    Manage shader assets (Layer 2 → Layer 1)
    list                          List available shader assets
    render <dir> [opts]           Compile shader to PNG frames
    extract <name> <out_dir>      Extract built-in manimlib shader
  mc <serve|stop> [args]          Motion Canvas dev server management
    serve <scene_dir> [port]      Start dev server
    stop <scene_dir>              Stop dev server
  cleanup [--dry-run]              Clean dead-PID stalled states (--logs prunes logs)
  dry-run <scene_file> [engine]    Fast pre-render validation (syntax, imports, LaTeX)
  test [suite|flags] [options]
                                   Run test suite
    --unit                         Fast pure-function tests (pytest)
    --integration                  Tool-chain combination tests
    --smoke                        End-to-end render tests
    --lint                         Static analysis (ruff)
    --all                          Run lint + unit + integration + smoke
    unit                           (legacy) Same as --unit
    integration                    (legacy) Same as --integration
    smoke                          (legacy) Same as --smoke
    all                            (legacy) Same as --all (without lint)
    --verbose                      Show all test output
    -k <pattern>                   Run only matching tests
    --fail-fast                    Stop on first failure
  status                          Show project status
  undo                            Revert last Agent change
  engine                          Show engine status & compatibility
  inspect [engine]                Query SOURCEMAP WHITELIST
    --grep <re>                   Filter by keyword regex
    --blacklist                   Show BLACKLIST instead
    --level P0|P1|P2              Filter by priority
    --format text|json            Output format (default: text)
  sourcemap <init|validate> [engine]
                                  Manage SOURCEMAP.md
  help                            Show this help

Examples:
  macode render scenes/01_test
  macode dev scenes/01_test --watch --port 3000
  macode check scenes/04_base_demo --static
  macode shader render assets/shaders/noise_heatmap/ --fps 30 --duration 3
  macode mc serve scenes/02_shader_mc
EOF
        ;;
esac
