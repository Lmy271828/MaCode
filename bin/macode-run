#!/usr/bin/env python3
"""
bin/macode-run
统一进程生命周期管理器（Harness 2.0）。

替代 bash trap + nohup + & wait，为所有渲染/处理任务提供：
- 可靠超时（SIGTERM → SIGKILL）
- 统一状态外化（state.json，MaCode Task State v1）
- 日志捕获（stdout/stderr 自动写入 .agent/log/，可选 tee）
- 信号转发（SIGINT/SIGTERM 转发给子进程）
- 子进程 task.json 合并（执行工具通过 MACODE_STATE_DIR 环境变量发现状态目录）

用法：
    macode-run <task_id> [options] -- <command...>

选项：
    --timeout <sec>      超时秒数（默认 600，0 表示无限制）
    --log <file>         日志文件路径
    --tee                同时输出到终端
    --no-state           不写入 state.json
    --state-dir <dir>    state.json 目录（默认 .agent/tmp/<task_id>）

环境变量：
    MACODE_TIMEOUT       默认超时秒数
    MACODE_LOG_DIR       日志目录（默认 .agent/log）

示例：
    macode-run 01_test --timeout 300 --tee -- \\
        bash engines/manim/scripts/render.sh scene.py out/ 30 3 1920 1080
"""

import argparse
import json
import os
import random
import signal
import string
import sys
import time
from datetime import datetime, timezone
from pathlib import Path
from subprocess import Popen, PIPE, TimeoutExpired


def get_project_root() -> str:
    return os.path.dirname(os.path.dirname(os.path.abspath(__file__)))


def write_state(state_path: str, data: dict):
    """原子写入 state.json。"""
    tmp = state_path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
        f.write("\n")
    os.replace(tmp, state_path)


def format_iso(dt: datetime) -> str:
    return dt.astimezone(timezone.utc).isoformat()


def merge_task_json(state_dir: str) -> dict:
    """读取子进程留下的 task.json 并返回 outputs 字典。"""
    task_path = os.path.join(state_dir, "task.json")
    if os.path.isfile(task_path):
        try:
            with open(task_path, "r", encoding="utf-8") as f:
                task = json.load(f)
            return task.get("outputs", {})
        except (json.JSONDecodeError, OSError):
            pass
    return {}


def main():
    parser = argparse.ArgumentParser(
        description="Run a command with lifecycle management (timeout, state, logs).",
        usage="%(prog)s <task_id> [options] -- <command...>",
        epilog="Examples:\n"
               "  %(prog)s 01_test -- bash engines/manim/scripts/render.sh scene.py out/ 30 3 1920 1080\n"
               "  %(prog)s 01_test --timeout 300 --tee -- node render-cli.mjs scenes/01_test_mc",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("task_id", help="Task identifier")
    parser.add_argument("--timeout", type=int, default=None, help="Timeout in seconds (0=unlimited)")
    parser.add_argument("--log", dest="log_file", default=None, help="Log file path")
    parser.add_argument("--tee", action="store_true", help="Also print output to terminal")
    parser.add_argument("--no-state", action="store_true", help="Skip writing state.json")
    parser.add_argument("--state-dir", default=None, help="Directory for state.json")
    parser.add_argument("--progress", action="store_true", help="Write phase events to .agent/progress/{task}.jsonl")
    parser.add_argument("cmd", nargs="*", help="Command to run after --")

    args = parser.parse_args()

    if not args.cmd:
        parser.error("No command provided after --")

    project_root = get_project_root()

    # Resolve paths
    state_dir = args.state_dir or os.path.join(".agent", "tmp", args.task_id)
    os.makedirs(state_dir, exist_ok=True)

    log_dir = os.environ.get("MACODE_LOG_DIR") or os.path.join(".agent", "log")
    os.makedirs(log_dir, exist_ok=True)

    log_file = args.log_file or os.path.join(
        log_dir, f"{datetime.now(timezone.utc).strftime('%Y%m%d_%H%M%S')}_{args.task_id}.log"
    )

    state_path = os.path.join(state_dir, "state.json")

    timeout = args.timeout
    if timeout is None:
        env_timeout = os.environ.get("MACODE_TIMEOUT", "")
        if env_timeout.isdigit():
            timeout = int(env_timeout)
        else:
            timeout = 600

    # Agent identity
    agent_id = os.environ.get("MACODE_AGENT_ID") or "agent-" + "".join(random.choices(string.ascii_lowercase + string.digits, k=6))

    # Write initial state (MaCode Task State v1)
    started_at = datetime.now(timezone.utc)
    state = {
        "version": "1.0",
        "taskId": args.task_id,
        "agentId": agent_id,
        "cmd": args.cmd,
        "status": "running",
        "startedAt": format_iso(started_at),
        "outputs": {},
    }
    if not args.no_state:
        write_state(state_path, state)

    def write_progress(phase: str, status: str, message: str = ""):
        if not args.progress:
            return
        progress_dir = os.path.join(".agent", "progress")
        os.makedirs(progress_dir, exist_ok=True)
        progress_path = os.path.join(progress_dir, f"{args.task_id}.jsonl")
        record = {
            "timestamp": format_iso(datetime.now(timezone.utc)),
            "phase": phase,
            "status": status,
        }
        if message:
            record["message"] = message
        with open(progress_path, "a", encoding="utf-8") as f:
            json.dump(record, f)
            f.write("\n")

    write_progress("init", "running", f"cmd: {' '.join(args.cmd)}")

    # Open log file
    log_fp = open(log_file, "w", encoding="utf-8")

    # Start subprocess with MACODE_STATE_DIR so child can write task.json
    env = os.environ.copy()
    env["MACODE_STATE_DIR"] = state_dir
    env["MACODE_AGENT_ID"] = agent_id
    child = Popen(
        args.cmd,
        stdout=PIPE,
        stderr=PIPE,
        cwd=project_root,
        env=env,
    )

    state["pid"] = child.pid
    if not args.no_state:
        write_state(state_path, state)

    if args.tee:
        print(f"[macode-run] Task '{args.task_id}' started (pid={child.pid}, timeout={timeout}s)")
        print(f"[macode-run] Log: {log_file}")
        if not args.no_state:
            print(f"[macode-run] State: {state_path}")
        if args.progress:
            print(f"[macode-run] Progress: .agent/progress/{args.task_id}.jsonl")

    # Signal forwarding setup
    child_terminated = False

    def forward_signal(signum, _frame):
        nonlocal child_terminated
        child_terminated = True
        sig_name = signal.Signals(signum).name
        if args.tee:
            print(f"[macode-run] Received {sig_name}, forwarding to child (pid={child.pid})")
        try:
            child.send_signal(signum)
        except ProcessLookupError:
            pass

    old_sigint = signal.signal(signal.SIGINT, forward_signal)
    old_sigterm = signal.signal(signal.SIGTERM, forward_signal)

    # Stream stdout/stderr to log file (and optionally tee)
    def pump_stream(stream, label: str):
        for line in stream:
            text = line.decode("utf-8", errors="replace")
            log_fp.write(text)
            log_fp.flush()
            if args.tee:
                print(f"[{label}] {text}", end="")

    # Use threads to pump both streams concurrently
    import threading
    t_out = threading.Thread(target=pump_stream, args=(child.stdout, "out"))
    t_err = threading.Thread(target=pump_stream, args=(child.stderr, "err"))
    t_out.start()
    t_err.start()

    # Wait with timeout
    exit_code = None
    status = "completed"
    try:
        if timeout > 0:
            exit_code = child.wait(timeout=timeout)
        else:
            exit_code = child.wait()
    except TimeoutExpired:
        if args.tee:
            print(f"[macode-run] Timeout after {timeout}s, sending SIGTERM...")
        try:
            child.terminate()
        except ProcessLookupError:
            pass
        try:
            child.wait(timeout=5)
        except TimeoutExpired:
            if args.tee:
                print("[macode-run] SIGTERM did not terminate child, sending SIGKILL...")
            try:
                child.kill()
            except ProcessLookupError:
                pass
            child.wait()
        exit_code = -signal.SIGTERM
        status = "timeout"

    # Wait for stream pumpers to finish
    t_out.join(timeout=5)
    t_err.join(timeout=5)
    log_fp.close()

    # Restore signal handlers
    signal.signal(signal.SIGINT, old_sigint)
    signal.signal(signal.SIGTERM, old_sigterm)

    # If child was terminated by signal (and not our timeout handling)
    if exit_code is None:
        exit_code = child.returncode
    if exit_code != 0 and status != "timeout" and not child_terminated:
        status = "failed"

    # Merge child task.json outputs
    child_outputs = merge_task_json(state_dir)

    ended_at = datetime.now(timezone.utc)
    state.update({
        "status": status,
        "exitCode": exit_code,
        "endedAt": format_iso(ended_at),
        "durationSec": round((ended_at - started_at).total_seconds(), 2),
        "outputs": child_outputs,
    })
    if not args.no_state:
        write_state(state_path, state)

    write_progress("cleanup", status, f"exit={exit_code}")

    if args.tee:
        print(f"[macode-run] Task '{args.task_id}' {status} (exit={exit_code})")

    sys.exit(exit_code if exit_code is not None else 1)


if __name__ == "__main__":
    main()
