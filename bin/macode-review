#!/usr/bin/env bash
set -euo pipefail

# bin/macode-review
# Human review CLI for asynchronous scene approval.
#
# Usage:
#   macode-review list                    # List all scenes awaiting review
#   macode-review approve <scene>         # Approve a scene
#   macode-review reject <scene> [reason] # Reject a scene
#   macode-review override <scene> --action retry --instruction "..."
#                                         # Request retry with instructions
#   macode-review log <scene>             # Show review history for a scene

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SIGNALS_DIR="$PROJECT_ROOT/.agent/signals/per-scene"

usage() {
    cat <<'EOF'
Usage: macode-review <command> [args]

Human review CLI for asynchronous scene approval.

Commands:
  list                          List all scenes awaiting review
  approve <scene>               Approve a scene
  reject <scene> [reason]       Reject a scene (optional reason)
  override <scene> --action <retry|skip> --instruction "..."
                                Override with specific action
  log <scene>                   Show review history for a scene

Examples:
  macode-review list
  macode-review approve 01_test
  macode-review reject 01_test "Text overlap on frame 120"
  macode-review override 01_test --action retry --instruction "Reduce font size by 20%"
EOF
}

list_reviews() {
    if [[ ! -d "$SIGNALS_DIR" ]]; then
        echo "No review queue."
        return 0
    fi

    local found=0
    for scene_dir in "$SIGNALS_DIR"/*; do
        [[ -d "$scene_dir" ]] || continue
        local scene_name
        scene_name="$(basename "$scene_dir")"
        if [[ -f "$scene_dir/review_needed" ]]; then
            found=1
            local mtime
            mtime="$(stat -c '%Y' "$scene_dir/review_needed" 2>/dev/null || echo '0')"
            local dt
            dt="$(date -d "@$mtime" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo 'unknown')"
            echo "  $scene_name    (since $dt)"
        fi
    done

    if [[ "$found" -eq 0 ]]; then
        echo "No scenes awaiting review."
    fi
}

approve_scene() {
    local scene="$1"
    local scene_dir="$SIGNALS_DIR/$scene"
    mkdir -p "$scene_dir"

    cat > "$scene_dir/human_override.json" <<EOF
{"action": "approve", "scene": "$scene", "timestamp": "$(date -Iseconds)"}
EOF
    echo "[review] Approved '$scene'. Agent will proceed on next check."
}

reject_scene() {
    local scene="$1"
    local reason="${2:-}"
    local scene_dir="$SIGNALS_DIR/$scene"
    mkdir -p "$scene_dir"

    cat > "$scene_dir/human_override.json" <<EOF
{"action": "reject", "scene": "$scene", "reason": "$reason", "timestamp": "$(date -Iseconds)"}
EOF
    echo "[review] Rejected '$scene'. Reason: $reason"
}

override_scene() {
    local scene="$1"
    shift
    local action=""
    local instruction=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --action) action="$2"; shift 2 ;;
            --instruction) instruction="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -z "$action" ]]; then
        echo "Error: --action required" >&2
        exit 1
    fi

    local scene_dir="$SIGNALS_DIR/$scene"
    mkdir -p "$scene_dir"

    cat > "$scene_dir/human_override.json" <<EOF
{"action": "$action", "scene": "$scene", "instruction": "$instruction", "timestamp": "$(date -Iseconds)"}
EOF
    echo "[review] Override '$scene': action=$action"
    if [[ -n "$instruction" ]]; then
        echo "  instruction: $instruction"
    fi
}

show_log() {
    local scene="$1"
    local scene_dir="$SIGNALS_DIR/$scene"

    if [[ ! -d "$scene_dir" ]]; then
        echo "No review history for '$scene'."
        return 0
    fi

    echo "Review state for '$scene':"
    echo ""

    if [[ -f "$scene_dir/review_needed" ]]; then
        echo "  Status: awaiting review"
    else
        echo "  Status: no pending review"
    fi

    if [[ -f "$scene_dir/human_override.json" ]]; then
        echo "  Pending override:"
        cat "$scene_dir/human_override.json" | python3 -m json.tool 2>/dev/null || cat "$scene_dir/human_override.json"
    fi

    if [[ -f "$scene_dir/frame_feedback.jsonl" ]]; then
        echo "  Frame feedback:"
        tail -5 "$scene_dir/frame_feedback.jsonl" | while read -r line; do
            echo "    $line"
        done
    fi
}

# ── Main dispatch ──
CMD="${1:-}"
shift || true

case "$CMD" in
    list)
        list_reviews
        ;;
    approve)
        [[ -z "${1:-}" ]] && { echo "Usage: macode-review approve <scene>" >&2; exit 1; }
        approve_scene "$1"
        ;;
    reject)
        [[ -z "${1:-}" ]] && { echo "Usage: macode-review reject <scene> [reason]" >&2; exit 1; }
        reject_scene "$1" "${2:-}"
        ;;
    override)
        [[ -z "${1:-}" ]] && { echo "Usage: macode-review override <scene> --action <retry|skip> --instruction \"...\"" >&2; exit 1; }
        override_scene "$@"
        ;;
    log)
        [[ -z "${1:-}" ]] && { echo "Usage: macode-review log <scene>" >&2; exit 1; }
        show_log "$1"
        ;;
    --help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $CMD" >&2
        usage
        exit 1
        ;;
esac
