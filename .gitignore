# MaCode .gitignore
# Agent workspace (ephemeral)
.agent/

# Runtime lock files (auto-created)
.agent/.git_lock
.agent/.render_semaphore

# Python virtual environments
.venv/
__pycache__/
*.pyc

# Node.js
node_modules/

# Output artifacts (videos, frames, audio)
output/
*.mp4
*.wav
*.mp3
*.png

# Editor / OS
.DS_Store
*.swp
*.swo
*~

# Windows Zone.Identifier files
*:Zone.Identifier
media/

# Motion Canvas runtime-generated files & build artifacts
engines/motion_canvas/project.ts
engines/motion_canvas/capture.ts
engines/motion_canvas/dist/

# Playwright local browser cache (auto-downloaded)
.ms-playwright/
